{
  "name": "bear-notes-chorus",
  "version": "26.03.28",
  "description": "Personal Bear Notes MCP fork for Chorus workflows.",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/main.ts --debug",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:system": "pnpm run build && vitest run --config vitest.system.config.ts",
    "test:watch": "vitest",
    "lint": "eslint src --fix",
    "lint:check": "eslint src",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "check": "pnpm run lint:check && pnpm run format:check",
    "fix": "pnpm run lint && pnpm run format"
  },
  "private": true,
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@modelcontextprotocol/ext-apps"
    ]
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "debug": "^4.4.3",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@anthropic-ai/mcpb": "^2.1.2",
    "@eslint/js": "^9.39.3",
    "@modelcontextprotocol/inspector": "^0.20.0",
    "@types/debug": "^4.1.12",
    "@types/node": "^24.10.13",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "^9.39.3",
    "eslint-plugin-import": "^2.32.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=24.13.0"
  },
  "keywords": [
    "bear app",
    "bear notes",
    "markdown notes",
    "notes management",
    "productivity",
    "typescript",
    "mcp"
  ],
  "author": {
    "name": "N8K",
    "url": "https://github.com/heyn8k"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chorusnotes/bear-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/chorusnotes/bear-mcp/issues"
  },
  "homepage": "https://github.com/chorusnotes/bear-mcp#readme",
  "packageManager": "pnpm@10.33.0"
}
